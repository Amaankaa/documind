DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/documind
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=gemini-embedding-2-preview
CHAT_MODEL=gemini-2.5-flash

CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Project URL only — do not append /rest/v1 (Storage API uses the root URL).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=documents

# Use local disk instead of Supabase (handy when offline or credentials are unset).
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_DIR=.local_storage

ALLOWED_ORIGINS=["http://localhost:3000"]
SENTRY_DSN=
