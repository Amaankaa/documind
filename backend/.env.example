DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/documind
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/documind
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

GEMINI_API_KEY=your-gemini-api-key

# LLM provider: gemini (direct) or laozhang (OpenAI-compatible proxy — https://docs.laozhang.ai)
LLM_PROVIDER=laozhang
LAOZHANG_API_KEY=sk-your-laozhang-api-key
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1

# When using laozhang, prefer OpenAI embedding + Gemini chat via proxy:
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gemini-2.5-flash
# EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=gemini-embedding-2-preview
CHAT_MODEL=gemini-2.5-flash

CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Project URL only — do not append /rest/v1 (Storage API uses the root URL).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=documents

# Use local disk instead of Supabase (handy when offline or credentials are unset).
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_DIR=.local_storage

# Community corpus sync (bundled notes + GitHub markdown → embed into community KB)
COMMUNITY_SYNC_ON_STARTUP=false
COMMUNITY_SYNC_INTERVAL_HOURS=6
COMMUNITY_KB_GITHUB_REPO=BemnetMussa/algorithm-knowledge-base
COMMUNITY_KB_GITHUB_BRANCH=main
ALGOMENTOR_GITHUB_REPO=Amaankaa/documind
ALGOMENTOR_GITHUB_BRANCH=main

# Tutor rate limits (protect server-side LLM API keys)
QUERY_RATE_LIMIT=20/minute
QUERY_DAILY_LIMIT_PER_USER=3

# Personal workspace upload cap (community corpus is unlimited)
MAX_CHUNKS_PER_KB=15

LLM_CREDENTIALS_SECRET=change-me-to-a-long-random-string

ALLOWED_ORIGINS=["http://localhost:3000"]
SENTRY_DSN=
