# Clerk (https://dashboard.clerk.com → API Keys)
# Development: pk_test_ / sk_test_  |  Production: pk_live_ / sk_live_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Backend API base URL
# Local: http://localhost:8000  |  Production: https://api.yourdomain.me
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk routing (Clerk v7 fallback redirect convention)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/map
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/map
